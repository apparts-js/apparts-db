{
  "name": "@apparts/db",
  "version": "3.12.0",
  "description": "Database drivers for multiple databases",
  "types": "build/index.d.ts",
  "main": "build/index.js",
  "scripts": {
    "prepublishOnly": "npm run ci && npm run clean && npm run build",
    "testOne": "vitest run",
    "test": "vitest",
    "testCoverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.release.json",
    "build:watch": "tsc -w -p tsconfig.release.json",
    "clean": "rimraf coverage build tmp",
    "ci": "npm ci && npm run ci:prettier && npm run ci:eslint && npm run ci:test",
    "ci:prettier": "CI=true prettier --check .",
    "ci:test": "CI=true vitest run",
    "ci:eslint": "eslint . --ext .js,.jsx,.ts,.tsx -c .eslintrc.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:phuhl/apparts-db.git"
  },
  "keywords": [
    "db",
    "database"
  ],
  "author": "Philipp Uhl",
  "license": "MIT",
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "better-sqlite3": "^11.10.0",
    "pg": "^8.15.5"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-dynamodb": {
      "optional": true
    },
    "@aws-sdk/lib-dynamodb": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apparts/config": "^1.0.6",
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@tsconfig/node14": "^1.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^18.19.0",
    "@types/pg": "^8.6.1",
    "@typescript-eslint/eslint-plugin": "^5.3.0",
    "@typescript-eslint/parser": "^5.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.7.0",
    "eslint-config-prettier": "^8.3.0",
    "pg": "^8.15.5",
    "prettier": "^2.5.1",
    "rimraf": "^3.0.2",
    "supertest": "^6.1.3",
    "tsutils": "^3.21.0",
    "typescript": "^4.4.4",
    "vitest": "^1.6.0"
  }
}
