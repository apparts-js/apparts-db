{
  "name": "@apparts/db",
  "version": "3.12.0",
  "description": "Database drivers for multiple databases",
  "types": "build/index.d.ts",
  "main": "build/index.js",
  "scripts": {
    "prepublishOnly": "npm run ci && npm run clean && npm run build",
    "testOne": "vitest run",
    "test": "vitest",
    "testCoverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.release.json",
    "build:watch": "tsc -w -p tsconfig.release.json",
    "clean": "rimraf coverage build tmp",
    "ci": "npm ci && npm run ci:prettier && npm run ci:eslint && npm run ci:test",
    "ci:prettier": "CI=true prettier --check .",
    "ci:test": "CI=true vitest run",
    "ci:eslint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:phuhl/apparts-db.git"
  },
  "keywords": [
    "db",
    "database"
  ],
  "author": "Philipp Uhl",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.15.5"
  },
  "devDependencies": {
    "@apparts/config": "^1.0.6",
    "@eslint/js": "^9.39.4",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.6.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jest": "^28.14.0",
    "globals": "^17.5.0",
    "prettier": "^2.5.1",
    "rimraf": "^3.0.2",
    "supertest": "^6.1.3",
    "tsutils": "^3.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.6.0"
  }
}
